{
  "name": "pingwatch",
  "version": "0.0.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Self-hosted, npm-distributed uptime + system monitoring — embedded NestJS + Next.js in one process, SQLite by default (Postgres/Redis opt-in).",
  "keywords": [
    "monitoring",
    "uptime",
    "status-page",
    "incidents",
    "self-hosted",
    "nestjs",
    "nextjs",
    "sqlite"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amit-2011/pingwatch.git"
  },
  "homepage": "https://github.com/amit-2011/pingwatch#readme",
  "engines": {
    "node": ">=22.12"
  },
  "type": "commonjs",
  "files": [
    "dist"
  ],
  "bin": {
    "pingwatch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.26",
    "@nestjs/schedule": "^6.1.3",
    "@pingwatch/db": "workspace:*",
    "@pingwatch/monitor-core": "workspace:*",
    "@pingwatch/notifications": "workspace:*",
    "@pingwatch/shared": "workspace:*",
    "@pingwatch/web": "workspace:*",
    "bullmq": "^5.78.1",
    "cac": "^7.0.0",
    "cookie-parser": "^1.4.7",
    "cosmiconfig": "^9.0.2",
    "express": "^5.2.1",
    "hash-wasm": "^4.12.0",
    "helmet": "^8.2.0",
    "ioredis": "^5.10.1",
    "ipaddr.js": "^2.4.0",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "next": "^15.5.19",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "systeminformation": "^5.31.7",
    "yaml": "^2.9.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
