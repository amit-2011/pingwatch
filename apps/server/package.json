{
  "name": "@pingwatch/server",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "bin": {
    "pingwatch": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "start": "node dist/cli.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.26",
    "@pingwatch/db": "workspace:*",
    "@pingwatch/monitor-core": "workspace:*",
    "@pingwatch/notifications": "workspace:*",
    "@pingwatch/shared": "workspace:*",
    "@pingwatch/web": "workspace:*",
    "cac": "^7.0.0",
    "cookie-parser": "^1.4.7",
    "cosmiconfig": "^9.0.2",
    "express": "^5.2.1",
    "hash-wasm": "^4.12.0",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "nestjs-pino": "^4.6.1",
    "next": "^15.5.19",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
